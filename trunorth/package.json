{
  "name": "trunorth",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:api\"",
    "dev:client": "vite",
    "dev:api": "tsx watch server/main.ts",
    "build": "tsc -p tsconfig.server.json --noEmit false 2>/dev/null || true && vite build",
    "preview": "vite preview",
    "demo": "vite build && vite preview --port 4173",
    "lint": "eslint src server api --max-warnings 0",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.api.json",
    "validate:content": "tsx scripts/validate-content.ts",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "db:migrate": "tsx server/db/migrate.ts",
    "start": "node dist-server/index.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@hono/node-server": "^1.14.0",
    "bcryptjs": "^3.0.2",
    "better-sqlite3": "^11.9.1",
    "hono": "^4.7.0",
    "jose": "^6.0.10",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.10",
    "@vitest/coverage-v8": "^3.0.9",
    "ajv": "^8.17.1",
    "concurrently": "^9.1.2",
    "eslint": "^9.22.0",
    "tsx": "^4.19.3",
    "typescript": "~5.8.2",
    "vite": "^6.2.2",
    "vitest": "^3.0.9"
  }
}
