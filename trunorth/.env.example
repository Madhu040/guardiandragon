# =============================================================================
# TruNorth configuration
# Copy to `.env` and adjust. Never commit real secrets.
#   cp .env.example .env
# =============================================================================

# --- Server (Hono API) -------------------------------------------------------
PORT=3001
HOST=0.0.0.0
JWT_SECRET=change-me-to-a-long-random-string-in-production
DATABASE_PATH=./data/trunorth.db

# Comma-separated browser origins allowed to call the API
CORS_ORIGINS=http://localhost:5173,http://localhost:4173,http://127.0.0.1:5173,http://127.0.0.1:4173

# --- AI Companion (optional — demo mode works without a key) -----------------
ANTHROPIC_API_KEY=
COMPANION_MODEL=claude-3-5-haiku-latest
CONFIDENCE_FLOOR=0.55
COMPANION_TIMEOUT_MS=8000

# --- Client (Vite — must be prefixed with VITE_ to reach the browser) --------
# Empty VITE_API_URL uses the Vite `/api` proxy (recommended for local + same Wi‑Fi via ngrok/LAN IP).
# Cross-device Play Together needs a reachable API; rooms expire ~2 hours.
VITE_API_URL=
VITE_DEMO_MODE=false

# Feature flags
VITE_FEATURE_PARENT_AUTH=true
VITE_FEATURE_TOGETHER_MODE=true
VITE_FEATURE_SCENARIO_HUB=true
VITE_FEATURE_WORLD_MOVEMENT=true
VITE_FEATURE_VOICE_OUTPUT=true

# Companion voice (on-device browser text-to-speech)
VITE_VOICE_RATE=0.95
VITE_VOICE_PITCH=1.1
VITE_VOICE_NAME=

# World movement (scene space is 1920×1080)
VITE_MOVE_SPEED=420
VITE_INTERACT_RADIUS=140
VITE_COMPANION_FOLLOW_LAG=0.88

# Gameplay defaults (Level 1: The Little Dragon Who Wouldn't Stop Guarding)
VITE_PRODUCT_NAME=TruNorth
VITE_DEFAULT_COMPANION_NAME=Flicker
VITE_DEFAULT_COMPANION_ARCHETYPE=companion_dragon
VITE_DEFAULT_CHAPTER_ID=ch2
VITE_DEFAULT_START_SCENE=w1
VITE_DEFAULT_AGE_BAND=5-7
VITE_DEFAULT_BASELINE_STRENGTH=worry_brave

# Timing (ms)
VITE_NARRATION_AUTO_ADVANCE_MS=2200
VITE_DEMO_COMPANION_DELAY_MS=350

# --- Dev tooling ports (used by vite.config.ts) ------------------------------
VITE_DEV_PORT=5173
VITE_API_PROXY_TARGET=http://localhost:3001
